---
import { SITE_TITLE } from '../consts';
import LinkedInIcon from '../assets/icons/linkedin_icon.png?url';
import GitHubIcon from '../assets/icons/github_icon.png?url';
---

<header>
	<nav>

		<div class="internal-links">
			<a href="/#top">Home</a>
			<a href="/#about">About</a>
			<a href="/#recent">Recent articles</a>
		</div>
		<div class="social-links">
			<a href="https://www.linkedin.com/in/ana-laura-tschen-moscoso-12ba59242/" target="_blank" rel="noreferrer noopener">
				<span class="sr-only">Follow Me on LinkedIn</span>
				<img src={LinkedInIcon} alt="LinkedIn" width="32" height="32" />
			</a>
			<a href="https://github.com/withastro/astro" target="_blank" rel="noreferrer noopener">
				<span class="sr-only">Follow Me on GitHub</span>
				<img src={GitHubIcon} alt="GitHub" width="32" height="32" />
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: rgba(var(--black), 0.95);
		box-shadow: 0 2px 18px rgba(0, 0, 0, 0.25);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--text));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a:hover {
		color: var(--accent);
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}

	.social-links img {
		width: 32px;
		height: 32px;
		display: block;
		object-fit: contain;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
