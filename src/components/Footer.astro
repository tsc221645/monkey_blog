---
const today = new Date();
import LinkedInIcon from '../assets/icons/linkedin_icon.png?url';
import GitHubIcon from '../assets/icons/github_icon.png?url';
---

<footer>
	&copy; {today.getFullYear()} Ana Tschen. All rights reserved.
	<div class="social-links">
		<a href="https://www.linkedin.com/in/ana-laura-tschen-moscoso-12ba59242/" target="_blank" rel="noreferrer noopener">
			<span class="sr-only">Follow Me on LinkedIn</span>
			<img src={LinkedInIcon} alt="LinkedIn" width="32" height="32" />
		</a>
		<a href="https://github.com/withastro/astro" target="_blank" rel="noreferrer noopener">
			<span class="sr-only">Follow Me on GitHub</span>
			<img src={GitHubIcon} alt="GitHub" width="32" height="32" />
		</a>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 4em 1em;
		background: rgba(var(--black), 0.95);
		color: rgb(var(--muted));
		text-align: center;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--muted));
	}
	.social-links a:hover {
		color: var(--accent);
	}
	.social-links img {
		width: 32px;
		height: 32px;
		display: block;
		object-fit: contain;
	}
</style>
