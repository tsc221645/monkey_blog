---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import PlaceholderImage from '../assets/blog-placeholder-1.jpg';
import RightArrowIcon from '../assets/icons/right_arrow_icon.png?url';
import { SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} />
	</head>
	<body>
		<Header />
		<main>
			<section id="top" class="hero">
				
				<h1>Welcome to the Monkey Blog</h1>

			</section>

			<section id="about" class="about">
				<h2>About me</h2>
				<p>
					Currently, I am a 5th year Computer Engineering student at Universidad del Valle de Guatemala.
					I am starting my 9th semester, which includes specialized courses related to my cybersecurity orientation.
				</p>

				<p>
					Outside of school, I enjoy working on personal projects. They range from building software applications
					and experimenting with data analysis to exploring operating systems, networking, and infrastructure.
					These projects allow me to continuously learn, solve real-world problems, and gain hands-on experience
					with different technologies.
				</p>

				<p>
					When I'm not coding, you'll probably find me training for running events, riding mountain bikes,
					or researching topics that caught my attention. I enjoy learning by building and believe that
					documenting the process is one of the best ways to deepen understanding.
				</p>

				<p>
					This blog serves as a place to document what I learn, share technical insights, and reflect on the
					challenges I encounter while building projects, studying new concepts, and exploring emerging technologies.
				</p>
			</section>

			<section id="recent" class="recent-posts">
				<div class="section-heading">
					<h2>Recent articles</h2>
				</div>
				<ul>
					{recentPosts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<Image
									class="recent-post-image"
									width={720}
									height={360}
									src={post.data.heroImage ?? PlaceholderImage}
									alt=""
								/>
								<div class="item-meta">
									<h3>{post.data.title}</h3>
									<time datetime={post.data.pubDate.toISOString()}>
										<FormattedDate date={post.data.pubDate} />
									</time>
								</div>
								<p>{post.data.description}</p>
							</a>
						</li>
					))}
				</ul>
				<a class="view-all" href="/blog">
					View all posts
					<img src={RightArrowIcon} alt="" width="18" height="18" />
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
